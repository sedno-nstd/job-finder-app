// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"  //postgresql
  url      = env("DATABASE_URL")
}

model User {
 id            String @id @default(cuid())
 name          String 
 email         String @unique
 phone         String? @unique
 emailVerified DateTime? 
 image         String?   
 accounts      Account[] 
 sessions      Session[]
 conversations Conversation[]
 messages      Message[]
 detailInfo    DetailInfo?
 verificationTokens VerificationToken[]
 applications Application[]
}

model Employer {
  id String @id @default(cuid())
  name String 
  email String @unique
  password String
  phone String 
  companyName String @unique

  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  vacancies Vacancy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model DetailInfo {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])

  firstName          String
  lastName           String
  resumeUrl          String?


  location           String
  gender             String
  dateOfBirth        String
  readyToRelocate    Boolean   @default(false)
  relocationLocations RelocationLocation[]
  readyForWorkAbroad Boolean   @default(false)

  desiredJob         DesiredJob[]  


  lastWorkplace      String
  previousPosition   String
  experienceDuration String  
  
  employmentType     EmploymentType[]
  
  searchMode         String
  role               String
  isCompleted        Boolean  @default(false)



  customImage String?

  salaryAmount String?
  salaryCurrency String @default("USD")
  salaryPeriod String @default("month")

  aboutMe String?
}


model RelocationLocation {
  id           String     @id @default(cuid())
  name         String
  detailInfoId String
  detailInfo   DetailInfo @relation(fields: [detailInfoId], references: [id])
}

model DesiredJob {
  id           String     @id @default(cuid())
  name         String
  detailInfoId String
  detailInfo   DetailInfo @relation(fields: [detailInfoId], references: [id])
}

model EmploymentType {
  id           String @id @default(cuid())
  name         String
  detailInfoId String
  detailInfo   DetailInfo @relation(fields: [detailInfoId],references: [id])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? 
  access_token       String? 
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? 
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String    @id @default(cuid())
  target     String   @unique
  type       String
  token      String   @unique
  expires    DateTime
  userId     String  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model Message {
 id        String @id @default(cuid())
 text      String

 author    User @relation(fields: [authorId], references: [id])
 authorId  String

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 chat      Conversation @relation(fields: [chatId], references: [id])
 chatId    String
}

model Conversation {
  id        String @id @default(cuid())
  users     User[]
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vacancy   Vacancy? @relation(fields: [vacancyId], references: [id])
  vacancyId String?
}

model Application {
  id  String @id @default(cuid())
  createdAt   DateTime @default(now())
  applicantId String
  applicant   User     @relation(fields: [applicantId], references: [id])
  vacancyId   String
  vacancy     Vacancy  @relation(fields: [vacancyId], references: [id])
  message     String?
  status      String   @default("pending")
  
}


model Vacancy {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String
  salaryFrom  Int?
  salaryTo    Int?
  currency    String   @default("UAH")
  salaryPeriod String  @default("month")
  negotiable  Boolean  @default(false)
  city        String?
  country     String
  level       String @default("junior")
  stack       String @default("")
  employmentType String  
  postedAt    DateTime @default(now())
  expiresAt   DateTime
  views       Int @default(0)
  employerId  String

  viewLogs      ViewLog[]
  employer      Employer          @relation(fields: [employerId], references: [id])
  application   Application[]
  conversation  Conversation[]
}

model ViewLog {
  id        String   @id @default(cuid())
  userIp    String
  createdAt DateTime @default(now())

  vacancyId String
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade) // Связь + удаление

  @@unique([vacancyId, userIp]) 
}